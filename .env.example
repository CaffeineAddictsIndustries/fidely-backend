# Environment variables for local development
# Use host.docker.internal instead of localhost when running Go from WSL against Docker Desktop
DATABASE_URL=postgres://fidely:fidely@localhost:5432/fidely?sslmode=disable
SERVER_PORT=8080
ENVIRONMENT=development

# Redis for distributed login rate limiting
REDIS_URL=redis://localhost:6379/0
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=1m

# Admin auth session settings
AUTH_SESSION_COOKIE_NAME=fidely_admin_session
AUTH_SESSION_TTL=12h
AUTH_SESSION_COOKIE_SECURE=false
AUTH_SESSION_COOKIE_SAMESITE=lax

# Optional extra secret for hashing admin session tokens
# Required in production
AUTH_TOKEN_HASH_PEPPER=change-this-in-production
